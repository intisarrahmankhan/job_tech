# --- HTTP ---
PORT=8000

# --- PostgreSQL ---
DATABASE_URL=host=localhost user=postgres password=postgres dbname=jobscout port=5432 sslmode=disable TimeZone=UTC

# --- Redis / Asynq ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Internal API protection ---
# Shared secret required in the X-Internal-Token header on POST /api/internal/jobs.
# The Python scraper must send the SAME value.
INTERNAL_API_TOKEN=change-me-in-prod

# --- Scraper worker ---
# Command the Go worker executes every 6 hours to trigger the Python scraper.
# On Windows use "python"; on macOS/Linux often "python3".
SCRAPER_CMD=python
SCRAPER_SCRIPT=../scrapers/scraper.py

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:8080,http://localhost:5173,http://localhost:3000
